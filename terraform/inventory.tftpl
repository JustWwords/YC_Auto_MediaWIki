---
server:
  children:
    proxy:
      hosts:
        vm_1:
          ansible_host: ${all_vms["vm-1"]}
    wiki:
      hosts:
%{ for name, ip in all_vms ~}
%{ if name != "vm-1" ~}
        ${replace(name, "-", "_")}:
          ansible_host: ${ip}
%{ endif ~}
%{ endfor ~}

  vars:
    ansible_user: "user"
    ansible_password: "qwerty"
    connection_protocol: ssh
    ansible_become: true
    ansible_become_method: sudo
